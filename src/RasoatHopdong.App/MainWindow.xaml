<Window x:Class="RasoatHopdong.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Rà soát hợp đồng"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F4F6F8">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#172033">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Rà soát hợp đồng"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Khung ứng dụng nền"
                               Margin="0,8,0,0"
                               Foreground="#B9C2D0"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,40,0,0">
                    <Border Background="#24314A" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                        <TextBlock Text="Tổng quan"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Padding="14,12" Margin="0,0,0,6">
                        <TextBlock Text="Rà soát hợp đồng"
                                   Foreground="#D8DEE9"
                                   FontSize="15" />
                    </Border>
                    <Border Padding="14,12" Margin="0,0,0,6">
                        <TextBlock Text="Bộ tiêu chí"
                                   Foreground="#D8DEE9"
                                   FontSize="15" />
                    </Border>
                    <Border Padding="14,12" Margin="0,0,0,6">
                        <TextBlock Text="Lịch sử"
                                   Foreground="#D8DEE9"
                                   FontSize="15" />
                    </Border>
                    <Border Padding="14,12">
                        <TextBlock Text="Cài đặt"
                                   Foreground="#D8DEE9"
                                   FontSize="15" />
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Giai đoạn 0 - Bước 0.3"
                           Foreground="#8F9BB0"
                           FontSize="12" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#FFFFFF">
            <wv2:WebView2 x:Name="LocalWebView" />

            <Border x:Name="WebViewFallback"
                    Visibility="Collapsed"
                    Margin="36"
                    Padding="24"
                    Background="#FFF7ED"
                    BorderBrush="#FED7AA"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Không thể tải giao diện local"
                               Foreground="#7C2D12"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WebViewFallbackText"
                               Margin="0,10,0,0"
                               Foreground="#9A3412"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
